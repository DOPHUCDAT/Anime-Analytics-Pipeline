 rank < 0 THEN ABS(rank)\n        ELSE rank\n    END::INT AS ranking,\n    TRIM(season) AS season,\n    CAST(year AS INT) AS year,\n    TRIM(status) AS status,\n    CASE\n        WHEN aired_to IS NOT NULL\n        AND aired_from IS NOT NULL\n        AND aired_to < aired_from THEN aired_to::date\n        ELSE aired_from::date\n    END AS aired_from,\n    CASE\n        WHEN aired_to IS NOT NULL\n        AND aired_from IS NOT NULL\n        AND aired_to < aired_from THEN aired_from::date\n        ELSE aired_to::date\n    END AS aired_to,\n    TRIM(studios) AS studios\nFROM anime_sk\nWHERE rn = 1", "relation_name": "\"anime_seasonal\".\"silver\".\"cleaned_data\"", "batch_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-04-04T04:38:48.855830Z", "completed_at": "2026-04-04T04:38:48.875687Z"}, {"name": "execute", "started_at": "2026-04-04T04:38:48.883648Z", "completed_at": "2026-04-04T04:38:49.303774Z"}], "thread_id": "Thread-2 (worker)", "execution_time": 0.47004222869873047, "adapter_response": {"_message": "INSERT 0 20650", "code": "INSERT", "rows_affected": 20650}, "message": "INSERT 0 20650", "failures": null, "unique_id": "model.anime_seasonal.dim_season", "compiled": true, "compiled_code": "\n\nWITH source_data AS (\n    SELECT *\n    FROM \"anime_seasonal\".\"silver\".\"cleaned_data\"\n)\nSELECT\n    anime_id,\n    season,\n    year\nFROM source_data", "relation_name": "\"anime_seasonal\".\"gold\".\"dim_season\"", "batch_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-04-04T04:38:48.841878Z", "completed_at": "2026-04-04T04:38:48.873224Z"}, {"name": "execute", "started_at": "2026-04-04T04:38:48.877229Z", "completed_at": "2026-04-04T04:38:49.335410Z"}], "thread_id": "Thread-3 (worker)", "execution_time": 0.5082454681396484, "adapter_response": {"_message": "INSERT 0 20650", "code": "INSERT", "rows_affected": 20650}, "message": "INSERT 0 20650", "failures": null, "unique_id": "model.anim