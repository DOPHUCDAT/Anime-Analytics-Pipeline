  anime_id,\n    season,\n    year,\n    aired_from\nFROM source_data\n\n\nWHERE aired_from > (SELECT max_aired_from FROM max_date)\n\n  );\n  \n  ", "name": "SQLQuery", "pid": 13171, "thread": "Thread-2 (worker)", "ts": "2026-04-03T14:48:08.196398Z"}}
