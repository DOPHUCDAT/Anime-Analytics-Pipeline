{"data": {"conn_name": "model.anime_seasonal.fact_anime", "node_info": {"materialized": "incremental", "meta": {}, "node_checksum": "98d72fda2d09018ba2a142a59eb9c904de35450ae0fed08ca310f43f8e7487dd", "node_finished_at": "", "node_name": "fact_anime", "node_path": "gold/fact_anime.sql", "node_relation": {"alias": "fact_anime", "database": "anime_seasonal", "relation_name": "\"anime_seasonal\".\"gold\".\"fact_anime\"", "schema": "gold"}, "node_started_at": "2026-04-03T14:48:08.301129", "node_status": "executing", "resource_type": "model", "unique_id": "model.anime_seasonal.fact_anime"}, "sql": "/* {\"app\": \"dbt\", \"dbt_version\": \"1.10.13\", \"profile_name\": \"anime_seasonal\", \"target_name\": \"dev\", \"node_id\": \"model.anime_seasonal.fact_anime\"} */\n\n    \n  \n    \n\n  create temporary table \"fact_anime__dbt_tmp214808346551\"\n  \n  \n    as\n  \n  (\n    \n\nWITH source_data AS (\n    SELECT *\n    FROM \"anime_seasonal\".\"silver\".\"cleaned_data\"\n),\n\nmax_date AS (\n    SELECT COALESCE(MAX(aired_from), '1900-01-01') AS max_aired_from\n    FROM \"anime_seasonal\".\"gold\".\"fact_anime\"\n)\n\nSELECT\n    anime_id,\n    score,\n    scored_by,\n    popularity,\n    members,\n    favorites,\n    ranking,\n    episodes,\n    aired_from\nFROM source_data\n\n\nWHERE aired_from > (SELECT max_aired_from FROM max_date)\n\n  );\n  \n  "}, "info": {"category": "", "code": "E016", "extra": {}, "invocation_id": "1f0f9950-5ac0-442b-86af-d43eb7af9837", "level": "debug", "msg": "On model.anime_seasonal.fact_anime: /* {\"app\": \"dbt\", \"dbt_version\": \"1.10.13\", \"profile_name\": \"anime_seasonal\", \"target_name\": \"dev\", \"node_id\": \"model.anime_seasonal.fact_anime\"} */\n\n    \n  \n    \n\n  create temporary table \"fact_anime__dbt_tmp214808346551\"\n  \n  \n    as\n  \n  (\n    \n\nWITH source_data AS (\n    SELECT *\n    FROM \"anime_seasonal\".\"silver\".\"cleaned_data\"\n),\n\nmax_date AS (\n    SELECT COALESCE(MAX(aired_from), '1900-01-01') AS max_aired_from\n    FROM \"anime_seasonal\".\"gold\".\"fact_anime\"\n)\n\nSELECT\n    anime_id,\n    score,\n    scored_by,\n    popularity,\n    members,\n    favorites,\n    ranking,\n    episodes,\n    aired_from\nFROM source_data\n\n\nWHERE aired_from > (SELECT max_aired_from FROM max_date)\n\n  );\n  \n  ", "name": "SQLQuery", "pid": 13171, "thread": "Thread-1 (worker)", "ts": "2026-04-03T14:48:08.358136Z"}}
