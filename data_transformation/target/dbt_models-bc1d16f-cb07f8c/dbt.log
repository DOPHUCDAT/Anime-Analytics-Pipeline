{"data": {"conn_name": "model.anime_seasonal.studio_performance", "node_info": {"materialized": "view", "meta": {}, "node_checksum": "df34294662f1cba92492716c3f09694ae10a3cefa1879a378da18538923a8423", "node_finished_at": "", "node_name": "studio_performance", "node_path": "mart/studio_performance.sql", "node_relation": {"alias": "studio_performance", "database": "anime_seasonal", "relation_name": "\"anime_seasonal\".\"mart\".\"studio_performance\"", "schema": "mart"}, "node_started_at": "2026-04-04T10:04:00.926247", "node_status": "executing", "resource_type": "model", "unique_id": "model.anime_seasonal.studio_performance"}, "sql": "/* {\"app\": \"dbt\", \"dbt_version\": \"1.10.13\", \"profile_name\": \"anime_seasonal\", \"target_name\": \"dev\", \"node_id\": \"model.anime_seasonal.studio_performance\"} */\n\n  create view \"anime_seasonal\".\"mart\".\"studio_performance__dbt_tmp\"\n    \n    \n  as (\n    \nSELECT st.studios,\n    count(distinct f.anime_id) AS total_anime,\n    round(avg(f.score), 2) AS avg_score,\n    sum(f.members) AS total_members,\n    sum(f.favorites) AS total_favorites\nFROM \"anime_seasonal\".\"gold\".\"fact_anime\" f\n    JOIN \"anime_seasonal\".\"gold\".\"dim_studios\" st ON f.anime_id = st.anime_id\nGROUP BY st.studios\n  );"}, "info": {"category": "", "code": "E016", "extra": {}, "invocation_id": "3c9bf026-b843-42f7-b823-07e9167cb8f3", "level": "debug", "msg": "On model.anime_seasonal.studio_performance: /* {\"app\": \"dbt\", \"dbt_version\": \"1.10.13\", \"profile_name\": \"anime_seasonal\", \"target_name\": \"dev\", \"node_id\": \"model.anime_seasonal.studio_performance\"} */\n\n  create view \"anime_seasonal\".\"mart\".\"studio_performance__dbt_tmp\"\n    \n    \n  as (\n    \nSELECT st.studios,\n    count(distinct f.anime_id) AS total_anime,\n    round(avg(f.score), 2) AS avg_score,\n    sum(f.members) AS total_members,\n    sum(f.favorites) AS total_favorites\nFROM \"anime_seasonal\".\"gold\".\"fact_anime\" f\n    JOIN \"anime_seasonal\".\"gold\".\"dim_studios\" st ON f.anime_id = st.anime_id\nGROUP BY st.studios\n  );", "name": "SQLQuery", "pid": 96317, "thread": "Thread-4 (worker)", "ts": "2026-04-04T10:04:01.007990Z"}}
