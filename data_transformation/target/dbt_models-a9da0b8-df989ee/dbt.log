ed_from\n    FROM \"anime_seasonal\".\"gold\".\"dim_info\"\n)\n\nSELECT\n    anime_id,\n    title,\n    type,\n    source,\n    status,\n    rating,\n\n    \n        genres\n    \n\nFROM \"anime_seasonal\".\"silver\".\"cleaned_data\"\n\n\nWHERE aired_from > (SELECT max_aired_from FROM max_date)\n\n  );\n  \n  ", "name": "SQLQuery", "pid": 17730, "thread": "Thread-4 (worker)", "ts": "2026-04-04T04:17:26.967291Z"}}
