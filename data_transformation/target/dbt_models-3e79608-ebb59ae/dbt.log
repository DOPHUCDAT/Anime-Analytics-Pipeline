{"data": {"conn_name": "model.anime_seasonal.anime_season_performance", "node_info": {"materialized": "view", "meta": {}, "node_checksum": "7c21e48d5a00291946c00425609660fa40fca1d13d8258107d41f23b3f1daab5", "node_finished_at": "", "node_name": "anime_season_performance", "node_path": "mart/anime_season_performance.sql", "node_relation": {"alias": "anime_season_performance", "database": "anime_seasonal", "relation_name": "\"anime_seasonal\".\"mart\".\"anime_season_performance\"", "schema": "mart"}, "node_started_at": "2026-04-04T10:17:54.655752", "node_status": "executing", "resource_type": "model", "unique_id": "model.anime_seasonal.anime_season_performance"}, "sql": "/* {\"app\": \"dbt\", \"dbt_version\": \"1.10.13\", \"profile_name\": \"anime_seasonal\", \"target_name\": \"dev\", \"node_id\": \"model.anime_seasonal.anime_season_performance\"} */\n\n  create view \"anime_seasonal\".\"mart\".\"anime_season_performance__dbt_tmp\"\n    \n    \n  as (\n    \nSELECT s.year,\n    s.season,\n    count(DISTINCT f.anime_id) AS total_anime,\n    round(avg(f.score), 2) AS avg_score,\n    sum(f.members) AS total_members,\n    sum(f.favorites) AS total_favorites\nFROM \"anime_seasonal\".\"gold\".\"fact_anime\" f\n    JOIN \"anime_seasonal\".\"gold\".\"dim_season\" s ON f.anime_id = s.anime_id\nGROUP BY s.year,\n    s.season\n  );"}, "info": {"category": "", "code": "E016", "extra": {}, "invocation_id": "50b6bf52-d888-4227-a712-b56afcf6209a", "level": "debug", "msg": "On model.anime_seasonal.anime_season_performance: /* {\"app\": \"dbt\", \"dbt_version\": \"1.10.13\", \"profile_name\": \"anime_seasonal\", \"target_name\": \"dev\", \"node_id\": \"model.anime_seasonal.anime_season_performance\"} */\n\n  create view \"anime_seasonal\".\"mart\".\"anime_season_performance__dbt_tmp\"\n    \n    \n  as (\n    \nSELECT s.year,\n    s.season,\n    count(DISTINCT f.anime_id) AS total_anime,\n    round(avg(f.score), 2) AS avg_score,\n    sum(f.members) AS total_members,\n    sum(f.favorites) AS total_favorites\nFROM \"anime_seasonal\".\"gold\".\"fact_anime\" f\n    JOIN \"anime_seasonal\".\"gold\".\"dim_season\" s ON f.anime_id = s.anime_id\nGROUP BY s.year,\n    s.season\n  );", "name": "SQLQuery", "pid": 28687, "thread": "Thread-4 (worker)", "ts": "2026-04-04T10:17:54.715740Z"}}
