{"data": {"conn_name": "model.anime_seasonal.top_10_anime_of_all_time", "node_info": {"materialized": "view", "meta": {}, "node_checksum": "3ad16230f535866dee3a745c5c970cfeee49114fc429b2642076fe8731388a39", "node_finished_at": "", "node_name": "top_10_anime_of_all_time", "node_path": "mart/top_10_anime_of_all_time.sql", "node_relation": {"alias": "top_10_anime_of_all_time", "database": "anime_seasonal", "relation_name": "\"anime_seasonal\".\"mart\".\"top_10_anime_of_all_time\"", "schema": "mart"}, "node_started_at": "2026-04-04T10:17:54.656673", "node_status": "executing", "resource_type": "model", "unique_id": "model.anime_seasonal.top_10_anime_of_all_time"}, "sql": "/* {\"app\": \"dbt\", \"dbt_version\": \"1.10.13\", \"profile_name\": \"anime_seasonal\", \"target_name\": \"dev\", \"node_id\": \"model.anime_seasonal.top_10_anime_of_all_time\"} */\n\n  create view \"anime_seasonal\".\"mart\".\"top_10_anime_of_all_time__dbt_tmp\"\n    \n    \n  as (\n    \nSELECT f.anime_id,\n    t.title,\n    s.year,\n    s.season,\n    f.score,\n    f.ranking,\n    f.members,\n    f.favorites\nFROM \"anime_seasonal\".\"gold\".\"fact_anime\" f\n    JOIN \"anime_seasonal\".\"gold\".\"dim_info\" t ON f.anime_id = t.anime_id\n    JOIN \"anime_seasonal\".\"gold\".\"dim_season\" s ON f.anime_id = s.anime_id\nWHERE f.score IS NOT NULL\nORDER BY f.score DESC\nLIMIT 10\n  );"}, "info": {"category": "", "code": "E016", "extra": {}, "invocation_id": "50b6bf52-d888-4227-a712-b56afcf6209a", "level": "debug", "msg": "On model.anime_seasonal.top_10_anime_of_all_time: /* {\"app\": \"dbt\", \"dbt_version\": \"1.10.13\", \"profile_name\": \"anime_seasonal\", \"target_name\": \"dev\", \"node_id\": \"model.anime_seasonal.top_10_anime_of_all_time\"} */\n\n  create view \"anime_seasonal\".\"mart\".\"top_10_anime_of_all_time__dbt_tmp\"\n    \n    \n  as (\n    \nSELECT f.anime_id,\n    t.title,\n    s.year,\n    s.season,\n    f.score,\n    f.ranking,\n    f.members,\n    f.favorites\nFROM \"anime_seasonal\".\"gold\".\"fact_anime\" f\n    JOIN \"anime_seasonal\".\"gold\".\"dim_info\" t ON f.anime_id = t.anime_id\n    JOIN \"anime_seasonal\".\"gold\".\"dim_season\" s ON f.anime_id = s.anime_id\nWHERE f.score IS NOT NULL\nORDER BY f.score DESC\nLIMIT 10\n  );", "name": "SQLQuery", "pid": 28687, "thread": "Thread-3 (worker)", "ts": "2026-04-04T10:17:54.718513Z"}}
